[core]
	fileMode = false
[include]
	path = .gitconfig-base
[credential]
    # this is actually needed to clear out any existing helpers
    helper =
    helper = git-credential-manager
    credentialStore = wincred
[diff]
	tool = bc
[difftool "bc"]
	path = "c:/program files (x86)/beyond compare 4/bcomp.exe"
[merge]
	tool = bc
[mergetool "bc"]
	path = "c:/program files (x86)/beyond compare 4/bcomp.exe"
