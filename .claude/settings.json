{
  "alwaysThinkingEnabled": true,
  "model": "opus",
  "effortLevel": "high",
  "autoUpdatesChannel": "latest",
  "theme": "dark-daltonized",
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "WebFetch(domain:*)",
      "WebSearch",
      "Read",
      "Glob",
      "Bash(grep:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh repo view:*)",
      "Bash(gh status:*)",
      "Bash(gh api:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git branch -v:*)",
      "Bash(git remote -v:*)",
      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(which:*)",
      "Bash(npm list:*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)"
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@anthropics-claude-code": true,
    "pyright-lsp@anthropics-claude-code": true
  }
}
